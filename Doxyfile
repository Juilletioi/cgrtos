INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 80
MAX_DOT_GRAPH_DEPTH    = 3
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = YES
HTML_TIMESTAMP         = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
STRIP_FROM_PATH        = /home/cong/cgrtos
WARN_NO_PARAMDOC       = NO
WARN_LOGFILE           = docs/doxygen/warnings.log
DOT_GRAPH_MAX_NODES    = 120
