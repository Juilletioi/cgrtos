# Doxyfile — CG-RTOS API documentation
PROJECT_NAME           = "CG-RTOS"
PROJECT_NUMBER           = 5.3.0
PROJECT_BRIEF          = "Multi-arch SMP multi-policy RTOS (RISC-V + AArch64)"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = Chinese
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES
RECURSIVE              = YES
