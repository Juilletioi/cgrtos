                         docs/PORTING.md docs/SCRIPTS.md docs/MODULE_CLI_VIM.md
FILE_PATTERNS          = *.c *.h *.S *.md
EXCLUDE_PATTERNS       = */build/* */sdk/* */docs/doxygen/*
USE_MDFILE_AS_MAINPAGE = docs/ARCHITECTURE.md
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HAVE_DOT               = YES
DOT_PATH               =
CALL_GRAPH             = YES
